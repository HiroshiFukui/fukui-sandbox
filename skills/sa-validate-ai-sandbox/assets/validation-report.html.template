<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BMAD AI Sandbox Validation Report</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; line-height: 1.6; color: #333; max-width: 900px; margin: 0 auto; padding: 20px; background-color: #f4f7f6; }
        .header { background: #2c3e50; color: #fff; padding: 20px; border-radius: 8px 8px 0 0; text-align: center; }
        .container { background: #fff; padding: 30px; border-radius: 0 0 8px 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .section { margin-bottom: 30px; border-bottom: 1px solid #eee; padding-bottom: 20px; }
        .section:last-child { border-bottom: none; }
        h1, h2, h3 { color: #2c3e50; }
        .status { font-weight: bold; padding: 5px 10px; border-radius: 4px; display: inline-block; }
        .status-pass { background-color: #d4edda; color: #155724; }
        .status-fail { background-color: #f8d7da; color: #721c24; }
        .status-warn { background-color: #fff3cd; color: #856404; }
        table { width: 100%; border-collapse: collapse; margin: 20px 0; }
        th, td { text-align: left; padding: 12px; border-bottom: 1px solid #ddd; }
        th { background-color: #f8f9fa; }
        .metric { font-weight: bold; width: 30%; }
        .footer { text-align: center; font-size: 0.9em; color: #777; margin-top: 20px; }
    </style>
</head>
<body>
    <div class="header">
        <h1>AI Sandbox Validation Report</h1>
        <p>Sandbox: <strong>{{sandbox_name}}</strong> | Timestamp: {{timestamp}}</p>
    </div>
    <div class="container">
        <div class="section">
            <h2>Executive Summary</h2>
            <p>Overall Status: <span class="status {{overall_status_class}}">{{overall_status}}</span></p>
            <p>{{summary_text}}</p>
        </div>

        <div class="section">
            <h2>1. Environment Check</h2>
            <table>
                <tr><th class="metric">Component</th><th>Result</th><th>Status</th></tr>
                <tr><td>Docker Engine</td><td>{{docker_version}}</td><td><span class="status {{docker_status_class}}">{{docker_status}}</span></td></tr>
                <tr><td>Docker Compose</td><td>{{compose_version}}</td><td><span class="status {{compose_status_class}}">{{compose_status}}</span></td></tr>
                <tr><td>NVIDIA GPU</td><td>{{gpu_info}}</td><td><span class="status {{gpu_status_class}}">{{gpu_status}}</span></td></tr>
                <tr><td>Operating System</td><td>{{os_info}}</td><td><span class="status {{os_status_class}}">{{os_status}}</span></td></tr>
            </table>
        </div>

        <div class="section">
            <h2>2. Network & Ports Audit</h2>
            <table>
                <tr><th class="metric">Check</th><th>Observation</th><th>Status</th></tr>
                <tr><td>Docker Network ({{network_name}})</td><td>{{network_obs}}</td><td><span class="status {{network_status_class}}">{{network_status}}</span></td></tr>
                <tr><td>Port Accessibility</td><td>{{ports_obs}}</td><td><span class="status {{ports_status_class}}">{{ports_status}}</span></td></tr>
            </table>
        </div>

        <div class="section">
            <h2>3. Compliance Audit</h2>
            <table>
                <tr><th class="metric">Standard</th><th>Observation</th><th>Status</th></tr>
                <tr><td>Directory Structure</td><td>{{structure_obs}}</td><td><span class="status {{structure_status_class}}">{{structure_status}}</span></td></tr>
                <tr><td>Mandatory Files</td><td>{{files_obs}}</td><td><span class="status {{files_status_class}}">{{files_status}}</span></td></tr>
                <tr><td>Permissions</td><td>{{perms_obs}}</td><td><span class="status {{perms_status_class}}">{{perms_status}}</span></td></tr>
            </table>
        </div>

        <div class="section">
            <h2>Recommendations</h2>
            <ul>
                {{#recommendations}}
                <li>{{.}}</li>
                {{/recommendations}}
            </ul>
        </div>
    </div>
    <div class="footer">
        Generated by BMad Workflow Builder | Module: AI Sandbox Architect (SA)
    </div>
</body>
</html>
